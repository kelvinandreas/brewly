# PostgreSQL
POSTGRES_USER=brewly
POSTGRES_PASSWORD=changeme
POSTGRES_DB=brewly
DATABASE_URL=postgres://brewly:changeme@postgres:5432/brewly?sslmode=disable

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_byte_hex_string
REFRESH_SECRET=replace_with_different_32_byte_hex_string
TABLE_TOKEN_SECRET=replace_with_yet_another_32_byte_hex_string

# YouTube Data API v3
YOUTUBE_API_KEY=

# Server
PORT=8080
ENV=development
LOG_LEVEL=debug

# Frontend
VITE_API_URL=http://localhost:8080
